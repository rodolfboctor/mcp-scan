# mcp-scan environment variables
# Copy to .env and fill in your values

# GitHub token for supply-chain scanner (GitHub Advisory Database lookups)
# Required for: npx mcp-scan --supply-chain
# Scopes needed: public_repo (read-only)
GITHUB_TOKEN=

# UGIG API key for enhanced vulnerability intelligence
# Get one at: https://ugig.io
# Required for: npx mcp-scan --ugig
UGIG_API_KEY=

# Slack webhook URL for alerting (optional)
# Required for: npx mcp-scan --slack-webhook <url>
# Create at: https://api.slack.com/messaging/webhooks
MCP_SCAN_SLACK_WEBHOOK=

# Webhook URL for generic alerting (optional)
# Required for: npx mcp-scan --webhook <url>
MCP_SCAN_WEBHOOK_URL=

# Path to custom policy file (optional, defaults to .mcp-scan.json)
MCP_SCAN_POLICY_FILE=
