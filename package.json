{
  "name": "mcp-scan",
  "version": "1.7.6",
  "description": "Security scanner for MCP servers.",
  "type": "module",
  "main": "./dist/lib.js",
  "module": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js",
      "require": "./dist/lib.cjs"
    }
  },
  "bin": {
    "mcp-scan": "./dist/index.js"
  },
  "files": [
    "dist",
    "data",
    "action.yml",
    "action/dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "xml2js": ">=0.5.0"
  },
  "scripts": {
    "build": "tsup && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('data',{recursive:true});cpSync('src/data/cve-snapshot.json','data/cve-snapshot.json');\"",
    "build:action": "tsup --config tsup.config.ts",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "update-cve-snapshot": "npx tsx src/scripts/update-cve-snapshot.ts",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodolfboctor/mcp-scan.git"
  },
  "keywords": [
    "mcp",
    "security",
    "scanner",
    "audit",
    "model-context-protocol"
  ],
  "author": "Abanoub Rodolf Boctor <rodolf@thynkq.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rodolfboctor/mcp-scan/issues"
  },
  "homepage": "https://thynkq.com/products/mcp-scan",
  "dependencies": {
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.4",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.0.1",
    "semver": "^7.7.4",
    "smol-toml": "^1.6.1",
    "uuid": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/node": "^20.12.7",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.1",
    "vuln-vects": "^1.1.0"
  }
}
